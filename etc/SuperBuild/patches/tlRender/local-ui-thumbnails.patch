@@ -19,6 +19,68 @@ namespace tl
 {
     namespace ui
     {
+        namespace
+        {
+            bool isSplitCompare(Compare compare)
+            {
+                return Compare::Horizontal == compare ||
+                    Compare::Vertical == compare;
+            }
+
+            ftk::Box2I getSplitSlot(
+                Compare compare,
+                size_t index,
+                const ftk::Size2I& viewportSize)
+            {
+                ftk::Box2I out(0, 0, viewportSize.w, viewportSize.h);
+                switch (compare)
+                {
+                case Compare::Horizontal:
+                {
+                    const int w0 = viewportSize.w / 2;
+                    out = index == 0 ?
+                        ftk::Box2I(0, 0, w0, viewportSize.h) :
+                        ftk::Box2I(w0, 0, viewportSize.w - w0, viewportSize.h);
+                    break;
+                }
+                case Compare::Vertical:
+                {
+                    const int h0 = viewportSize.h / 2;
+                    out = index == 0 ?
+                        ftk::Box2I(0, 0, viewportSize.w, h0) :
+                        ftk::Box2I(0, h0, viewportSize.w, viewportSize.h - h0);
+                    break;
+                }
+                default: break;
+                }
+                return out;
+            }
+
+            ftk::Box2I getSplitSlotForPos(
+                Compare compare,
+                const ftk::Size2I& viewportSize,
+                const ftk::V2I& pos)
+            {
+                size_t index = 0;
+                switch (compare)
+                {
+                case Compare::Horizontal:
+                    index = pos.x >= viewportSize.w / 2 ? 1 : 0;
+                    break;
+                case Compare::Vertical:
+                    index = pos.y >= viewportSize.h / 2 ? 1 : 0;
+                    break;
+                default: break;
+                }
+                return getSplitSlot(compare, index, viewportSize);
+            }
+
+            ftk::Size2I getFrameRenderSize(const VideoFrame& frame)
+            {
+                return getRenderSize(Compare::A, std::vector<VideoFrame>({ frame }));
+            }
