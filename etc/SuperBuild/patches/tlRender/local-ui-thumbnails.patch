+            //! Timeline filmstrips use a separate decode path from playback.
+            IOOptions thumbnailIOOptions(const IOOptions& value)
+            {
+                IOOptions out = value;
+                out["FFmpeg/HardwareDecode"] = "Off";
+                out["FFmpeg/ThreadCount"] = "2";
+                return out;
+            }
+
+            constexpr size_t maxPendingThumbnailRequests = 12;
+            constexpr int maxFilmstripCells = 10;
+
+            int thumbnailDecodeHeight(int displayHeight)
+            {
+                return std::max(48, (displayHeight * 3) / 4);
+            }
+
+            void getFilmstripLayout(
+                int timelineWidth,
+                int idealThumbnailWidth,
+                int& outCellCount,
+                int& outCellWidth)
+            {
+                outCellCount = 1;
+                outCellWidth = timelineWidth;
+                if (timelineWidth <= 0 || idealThumbnailWidth <= 0)
+                {
+                    return;
+                }
+                outCellCount = std::max(
+                    1,
+                    (timelineWidth + idealThumbnailWidth - 1) / idealThumbnailWidth);
+                outCellCount = std::min(outCellCount, maxFilmstripCells);
+                outCellWidth = std::max(1, timelineWidth / outCellCount);
+            }
+        }
